{
  "name": "tree-of-thoughts",
  "version": "0.4.5",
  "description": "Tree of Thoughts MCP server — structured multi-path reasoning with persistent storage, hybrid retrieval, knowledge graph, experiment runner, and live dashboard",
  "author": {
    "name": "viraf-pro"
  },
  "homepage": "https://github.com/viraf-pro/tree-of-thoughts",
  "repository": "https://github.com/viraf-pro/tree-of-thoughts",
  "license": "MIT",
  "keywords": [
    "tree-of-thoughts",
    "reasoning",
    "mcp",
    "knowledge-graph",
    "retrieval",
    "experiments",
    "dashboard"
  ],
  "mcpServers": {
    "tree-of-thoughts": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/launch.sh",
      "env": {
        "TOT_DB_PATH": "${CLAUDE_PLUGIN_DATA}/tot.db",
        "TOT_DASHBOARD_PORT": "4545"
      }
    }
  }
}
